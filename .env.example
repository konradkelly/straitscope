# Copy to .env and fill in

# Get a free key at https://aisstream.io
AISSTREAM_API_KEY=

# Local Postgres password (any strong value)
DB_PASSWORD=

# Used by `npm run dev` when ingest/worker run on the host (not in Docker),
# connecting to the db container via its published port (5434, since 5432 is
# often taken by a local Postgres install). Keep the password in sync with
# DB_PASSWORD above.
DATABASE_URL=postgres://strait:changeme@localhost:5434/strait

# Optional tuning
# INSERT_BATCH_SIZE=200
# INSERT_FLUSH_MS=2000
# WORKER_INTERVAL_MS=300000
# ABANDON_AFTER_HOURS=48
# DARK_AFTER_HOURS=6
# PORT=8080
