# Copy to terraform.tfvars and fill in. Do not commit terraform.tfvars
# (it's gitignored) since it will contain your SSH public key and IP.

aws_region    = "us-east-1"
project_name  = "straitscope"
domain_name   = "straitscope.com"

# Find yours with: curl ifconfig.me
admin_ip_cidr = "203.0.113.4/32"

# cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... konradky@gmail.com"

# Recommended so Let's Encrypt can email you before cert expiry issues.
acme_email = "konradky@gmail.com"

instance_type        = "t3.small"
root_volume_size_gb  = 30
