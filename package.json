{
  "name": "strait-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:db && concurrently -k -n ingest,worker,api -c blue,green,magenta \"node --watch --env-file=.env src/ingest.js\" \"node --watch --env-file=.env src/worker.js\" \"node --watch --env-file=.env src/api.js\"",
    "dev:db": "docker compose up -d --wait db",
    "ingest": "node src/ingest.js",
    "worker": "node src/worker.js",
    "api": "node src/api.js",
    "test": "node --test test/",
    "export-tracks": "node --env-file=.env tools/export-tracks.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.9.0",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
